#!/usr/bin/env python3
"""autowrite — multi-paper management CLI (Python stdlib only).

Subcommands:
    new <slug>       Scaffold a new paper under papers/<slug>/
    switch <slug>    Set papers/.current to <slug>
    status           Show current paper + recent iterations
    list             List all papers with their titles
    validate         Integrity checks on current paper
    kb-sync          Incremental knowledge graph update from raw/

Design: one source of truth per paper (papers/<slug>/paper.md frontmatter).
Zero external deps. Reuses git for history and incremental diffing.
"""
import argparse
import json
import os
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from src.agents import OrchestratorAgent, ResearcherAgent, WriterAgent, CriticAgent, ValidatorAgent

PAPERS = ROOT / "papers"
CURRENT = PAPERS / ".current"
RAW = ROOT / "raw"


def normalize_slug(slug):
    slug = str(slug).strip()
    if not re.fullmatch(r"[a-z0-9][a-z0-9-]*", slug):
        sys.exit(f"error: invalid paper slug: {slug}")
    return slug
BUILD_SCRIPT = ROOT / "scripts" / "build_paper_graph.py"
STATE_DIR = ROOT / ".autowrite"
AGENTS_STATE = STATE_DIR / "agents.json"

RESULTS_HEADER = "iteration\tcommit\told_score\tnew_score\tdimension\tstatus\teval_mode\tnote\n"

PAPER_TEMPLATE = """---
slug: {slug}
title: {title}
thesis: "[待填写 — 一句话核心论点。所有 edit 必须服务于它，否则 discard。]"
scope_in: []
scope_out: []
audience: "[目标读者]"
contribution: empirical
branch_baseline: {branch}
raw_subset: []
created_at: {date}
---

# {title}

## Abstract

[待证据收集完成后由 agent 撰写]

## 1. Introduction

## 2. Literature Review

## 3. Framework

## 4. Methodology

## 5. Findings

## 6. Discussion

## 7. Conclusion

## References
"""

READER_PROMPTS_TEMPLATE = """# Reader Prompts — {title}

> 3–5 条对抗性读者问题。每 3 轮 keep 后，独立子 agent 用这些 prompt 测试 paper.md。

## P1. 核心质疑
持相反立场的审稿人会如何反驳本文的 thesis？本文在哪一节作出了回应？

## P2. 证据充分性
本文最弱的 3 个 claim 是什么？证据链条是否支撑结论？

## P3. 范围与泛化
结论能否泛化到 scope_out 之外？哪些限定条件应写入 Discussion？

## P4. 方法透明度
复现者仅凭 §Methodology 能否复现分析路径？缺哪些细节？

## P5. 反事实鲁棒性
若关键证据反转，结论如何变化？文中是否承认这种脆弱性？
"""


agent_instances = {}
orchestrator_instance = None


def ensure_state_dir():
    STATE_DIR.mkdir(exist_ok=True)


def load_agents_state():
    ensure_state_dir()
    if not AGENTS_STATE.exists():
        return {"agents": []}
    try:
        return json.loads(AGENTS_STATE.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {"agents": []}


def _pid_alive(pid):
    try:
        os.kill(int(pid), 0)
        return True
    except Exception:
        return False


def reconcile_agents_state(state):
    live = []
    for record in state.get("agents", []):
        pid = record.get("pid")
        if pid and _pid_alive(pid):
            record["status"] = "running"
            live.append(record)
    state["agents"] = live
    return state


def save_agents_state(state):
    ensure_state_dir()
    AGENTS_STATE.write_text(json.dumps(state, indent=2, ensure_ascii=False), encoding="utf-8")


def _find_agent_record(state, agent_id):
    for record in state.get("agents", []):
        if record.get("agent_id") == agent_id:
            return record
    return None


def start_agent(agent_type, agent_id=None):
    global orchestrator_instance
    cls_map = {
        "orchestrator": OrchestratorAgent,
        "researcher": ResearcherAgent,
        "writer": WriterAgent,
        "critic": CriticAgent,
        "validator": ValidatorAgent,
    }
    cls = cls_map.get(agent_type)
    if not cls:
        sys.exit(f"error: unknown agent type: {agent_type}")

    state = reconcile_agents_state(load_agents_state())
    if agent_type == "orchestrator":
        existing = next((a for a in state.get("agents", []) if a.get("type") == "orchestrator"), None)
        if existing:
            print(f"orchestrator already registered: {existing['agent_id']}")
            return existing

    agent = cls(agent_id)
    agent_instances[agent.agent_id] = agent

    if agent_type == "orchestrator":
        orchestrator_instance = agent
    elif orchestrator_instance is not None:
        orchestrator_instance.register_agent(agent)

    state.setdefault("agents", []).append({
        "agent_id": agent.agent_id,
        "type": agent_type,
        "name": agent.name,
        "created_at": datetime.now().isoformat(timespec="seconds"),
        "status": "running",
        "pid": os.getpid(),
    })
    save_agents_state(state)
    print(f"started {agent.name}: {agent.agent_id}")
    return agent


def stop_agent(agent_id):
    global orchestrator_instance
    state = reconcile_agents_state(load_agents_state())
    record = _find_agent_record(state, agent_id)
    if not record:
        sys.exit(f"error: agent not found: {agent_id}")

    agent = agent_instances.get(agent_id)
    if agent is not None:
        agent.stop()
        del agent_instances[agent_id]

    state["agents"] = [a for a in state.get("agents", []) if a.get("agent_id") != agent_id]
    save_agents_state(state)

    if orchestrator_instance and getattr(orchestrator_instance, "agent_id", None) == agent_id:
        orchestrator_instance = None
    print(f"stopped agent: {agent_id}")


def list_agents_cmd():
    state = reconcile_agents_state(load_agents_state())
    save_agents_state(state)
    agents = state.get("agents", [])
    if not agents:
        print("no running agents")
        return
    for record in agents:
        print(f"{record['name']}\t{record['type']}\t{record['agent_id']}\t{record['status']}")


def ensure_default_orchestrator():
    state = reconcile_agents_state(load_agents_state())
    existing = next((a for a in state.get("agents", []) if a.get("type") == "orchestrator"), None)
    if existing:
        return existing
    return start_agent("orchestrator")


def get_current_paper_context():
    slug = read_current()
    if not slug:
        return None
    d = paper_dir(slug)
    paper_md = d / "paper.md"
    fm = parse_frontmatter(paper_md) if paper_md.exists() else {}
    return {
        "slug": slug,
        "paper_dir": d,
        "frontmatter": fm,
    }


def save_research_run(slug, payload):
    paper_path = paper_dir(slug)
    runs_dir = paper_path / "research_runs"
    runs_dir.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    out = runs_dir / f"{stamp}.json"
    out.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
    return out


def ensure_research_artifacts(slug):
    paper_path = paper_dir(slug)
    paper_path.mkdir(parents=True, exist_ok=True)

    graph_path = paper_path / "paper_graph.json"
    if not graph_path.exists():
        graph_path.write_text(
            json.dumps(
                {
                    "_meta": {"slug": slug, "created_by": "agent_research", "last_scan_commit": None},
                    "nodes": [],
                    "edges": [],
                    "metadata": {"research_runs": 0, "total_nodes": 0, "total_edges": 0},
                },
                indent=2,
                ensure_ascii=False,
            ),
            encoding="utf-8",
        )

    results_path = paper_path / "results.tsv"
    if not results_path.exists():
        results_path.write_text(RESULTS_HEADER, encoding="utf-8")

    return graph_path, results_path


def merge_research_into_graph(slug, payload):
    graph_path, _ = ensure_research_artifacts(slug)
    data = json.loads(graph_path.read_text(encoding="utf-8"))
    data.setdefault("nodes", [])
    data.setdefault("edges", [])
    data.setdefault("metadata", {})
    data.setdefault("_meta", {})

    run_id = payload.get("run_id") or datetime.now().strftime("%Y%m%d_%H%M%S")
    merged_runs = set(data["_meta"].get("merged_research_runs", []))
    if run_id in merged_runs:
        return {"graph_path": graph_path, "nodes_added": 0, "edges_added": 0}

    topic = payload.get("topic", "research")
    source_file = payload.get("saved_to", "agent_run")

    existing_nodes = {(n.get("type"), n.get("label"), n.get("source_file")): n.get("id") for n in data["nodes"]}
    existing_ids = {n.get("id") for n in data["nodes"]}
    existing_edges = {(e.get("source"), e.get("target"), e.get("relation")) for e in data["edges"]}

    def ensure_node(node_id, node_type, label, section, source):
        key = (node_type, label, source)
        existing = existing_nodes.get(key)
        if existing:
            return existing, False
        candidate_id = node_id
        suffix = 1
        while candidate_id in existing_ids:
            suffix += 1
            candidate_id = f"{node_id}_{suffix}"
        data["nodes"].append({
            "id": candidate_id,
            "type": node_type,
            "label": label,
            "section": section,
            "source_file": source,
            "run_id": run_id,
        })
        existing_nodes[key] = candidate_id
        existing_ids.add(candidate_id)
        return candidate_id, True

    def ensure_edge(source, target, relation, confidence_score):
        key = (source, target, relation)
        if key in existing_edges:
            return False
        data["edges"].append({
            "source": source,
            "target": target,
            "relation": relation,
            "confidence": "AGENT",
            "confidence_score": confidence_score,
        })
        existing_edges.add(key)
        return True

    topic_id, added = ensure_node(
        f"concept_research_{re.sub(r'[^a-z0-9_]+', '_', topic.lower())[:40]}",
        "CONCEPT",
        topic,
        "research_run",
        source_file,
    )
    node_count = 1 if added else 0
    edge_count = 0

    for q_idx, item in enumerate(payload.get("evidence", []), start=1):
        question = item.get("question", f"question_{q_idx}")[:200]
        claim_id, added = ensure_node(
            f"claim_research_{run_id}_{re.sub(r'[^a-z0-9_]+', '_', question.lower())[:50]}",
            "CLAIM",
            question,
            "research_run",
            source_file,
        )
        if added:
            node_count += 1
        if ensure_edge(topic_id, claim_id, "EXTENDS", 0.6):
            edge_count += 1

        for f_idx, finding in enumerate(item.get("findings", []), start=1):
            evidence_label = finding.get("claim", "")[:200]
            evidence_source = finding.get("source", source_file)
            evidence_id, added = ensure_node(
                f"evidence_research_{run_id}_{re.sub(r'[^a-z0-9_]+', '_', evidence_label.lower())[:50]}_{f_idx}",
                "EVIDENCE",
                evidence_label,
                "research_run",
                evidence_source,
            )
            if added:
                node_count += 1
            if ensure_edge(claim_id, evidence_id, "SUPPORTS", float(finding.get("support", 0.3))):
                edge_count += 1

    data["metadata"]["research_runs"] = int(data["metadata"].get("research_runs", 0)) + 1
    data["metadata"]["total_nodes"] = len(data["nodes"])
    data["metadata"]["total_edges"] = len(data["edges"])
    data["_meta"]["last_agent_research_at"] = datetime.now().isoformat(timespec="seconds")
    data["_meta"]["last_research_run_id"] = run_id
    merged_runs.add(run_id)
    data["_meta"]["merged_research_runs"] = sorted(merged_runs)
    graph_path.write_text(json.dumps(data, indent=2, ensure_ascii=False), encoding="utf-8")
    return {"graph_path": graph_path, "nodes_added": node_count, "edges_added": edge_count}


def append_research_to_results(slug, payload):
    _, results_path = ensure_research_artifacts(slug)
    head = run_git("rev-parse", "--short", "HEAD").strip() or "-"
    total_findings = sum(len(item.get("findings", [])) for item in payload.get("evidence", []))
    note = f"run research: {len(payload.get('questions', []))} questions, {total_findings} findings, topic={payload.get('topic', '')}"
    with results_path.open("a", encoding="utf-8") as f:
        f.write(f"-\t{head}\t-\t-\tresearch\trecorded\tagent_run\t{note}\n")
    return results_path


def append_generic_result(slug, dimension, status, eval_mode, note, old_score="-", new_score="-"):
    _, results_path = ensure_research_artifacts(slug)
    head = run_git("rev-parse", "--short", "HEAD").strip() or "-"
    with results_path.open("a", encoding="utf-8") as f:
        f.write(f"-\t{head}\t{old_score}\t{new_score}\t{dimension}\t{status}\t{eval_mode}\t{note}\n")
    return results_path


def latest_research_run(slug):
    runs_dir = paper_dir(slug) / "research_runs"
    if not runs_dir.exists():
        return None
    files = sorted(runs_dir.glob("*.json"))
    if not files:
        return None
    latest = files[-1]
    return latest, json.loads(latest.read_text(encoding="utf-8"))


def save_artifact(slug, artifact_type, payload):
    base = paper_dir(slug) / artifact_type
    base.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    out = base / f"{stamp}.json"
    out.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
    return out


def begin_iteration_snapshot(slug):
    paper_path = paper_dir(slug)
    snapshots_dir = paper_path / "snapshots"
    snapshots_dir.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    snapshot_path = snapshots_dir / f"{stamp}.json"

    paper_md = paper_path / "paper.md"
    graph_path = paper_path / "paper_graph.json"
    results_path = paper_path / "results.tsv"

    payload = {
        "slug": slug,
        "created_at": datetime.now().isoformat(timespec="seconds"),
        "paper_md": paper_md.read_text(encoding="utf-8") if paper_md.exists() else None,
        "paper_graph_json": graph_path.read_text(encoding="utf-8") if graph_path.exists() else None,
        "results_tsv": results_path.read_text(encoding="utf-8") if results_path.exists() else None,
    }
    snapshot_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
    return snapshot_path


def restore_iteration_snapshot(slug, snapshot_path):
    paper_path = paper_dir(slug)
    payload = json.loads(Path(snapshot_path).read_text(encoding="utf-8"))

    paper_md = paper_path / "paper.md"
    graph_path = paper_path / "paper_graph.json"
    results_path = paper_path / "results.tsv"

    if payload.get("paper_md") is not None:
        paper_md.write_text(payload["paper_md"], encoding="utf-8")
    if payload.get("paper_graph_json") is not None:
        graph_path.write_text(payload["paper_graph_json"], encoding="utf-8")
    if payload.get("results_tsv") is not None:
        results_path.write_text(payload["results_tsv"], encoding="utf-8")

    return {
        "paper_md": str(paper_md.relative_to(ROOT)),
        "paper_graph_json": str(graph_path.relative_to(ROOT)),
        "results_tsv": str(results_path.relative_to(ROOT)),
    }


def ensure_paper_md(slug):
    paper_path = paper_dir(slug)
    paper_path.mkdir(parents=True, exist_ok=True)
    md = paper_path / "paper.md"
    if not md.exists():
        md.write_text(
            PAPER_TEMPLATE.format(
                slug=slug,
                title=slug.replace('-', ' ').title(),
                branch=run_git("rev-parse", "--abbrev-ref", "HEAD").strip() or "main",
                date=datetime.now().strftime("%Y-%m-%d"),
            ),
            encoding="utf-8",
        )
    return md


def route_section_title(topic, existing_titles, requested_title=None):
    if requested_title and requested_title.strip():
        return requested_title.strip()

    topic_lower = (topic or "").lower()
    existing_titles = existing_titles or []
    routing_rules = [
        (["finding", "evidence", "indicator", "service", "public service"], ["findings"]),
        (["discussion", "implication", "limitation", "counterargument"], ["discussion"]),
        (["method", "mechanism", "pathway"], ["methodology", "framework"]),
        (["conclusion", "summary", "recommendation"], ["conclusion"]),
        (["ecological", "governance", "development"], ["discussion", "findings"]),
    ]

    for topic_keys, title_keys in routing_rules:
        if any(k in topic_lower for k in topic_keys):
            for title in existing_titles:
                title_lower = title.lower()
                if any(k in title_lower for k in title_keys):
                    return title

    return "Agent Draft"



def apply_latest_draft(section_title=None):
    paper_ctx = get_current_paper_context()
    if not paper_ctx:
        sys.exit("error: no active paper")

    drafts_dir = paper_dir(paper_ctx["slug"]) / "drafts"
    files = sorted(drafts_dir.glob("*.json")) if drafts_dir.exists() else []
    if not files:
        sys.exit("error: no draft found for current paper")
    draft_payload = json.loads(files[-1].read_text(encoding="utf-8"))

    paper_md = ensure_paper_md(paper_ctx["slug"])
    text = paper_md.read_text(encoding="utf-8")
    existing_titles = re.findall(r"^##\s+(.+)$", text, re.MULTILINE)
    title = route_section_title(draft_payload.get("source_research_topic") or draft_payload.get("section_title"), existing_titles, requested_title=section_title or draft_payload.get("section_title"))
    draft_body = draft_payload.get('draft', '').strip()
    pattern = re.compile(rf"(^##\s+{re.escape(title)}\s*$)(.*?)(?=^##\s+|\Z)", re.MULTILINE | re.DOTALL)
    match = pattern.search(text)

    mode = "append"
    previous_excerpt = None
    if match:
        mode = "replace"
        previous_excerpt = match.group(2).strip()[:300]
        replacement = f"## {title}\n\n{draft_body}\n\n"
        text = text[:match.start()] + replacement + text[match.end():]
    else:
        text = text.rstrip() + f"\n\n## {title}\n\n{draft_body}\n"

    paper_md.write_text(text, encoding="utf-8")

    payload = {
        "paper": paper_ctx["slug"],
        "draft_source": str(files[-1].relative_to(ROOT)),
        "applied_section": title,
        "mode": mode,
        "previous_excerpt": previous_excerpt,
        "new_excerpt": draft_body[:300],
        "paper_md": str(paper_md.relative_to(ROOT)),
        "generated_at": datetime.now().isoformat(timespec="seconds"),
    }
    out = save_artifact(paper_ctx["slug"], "applied_drafts", payload)
    payload["saved_to"] = str(out.relative_to(ROOT))
    append_generic_result(paper_ctx["slug"], "apply_draft", "recorded", "agent_run", f"applied draft to section: {title} ({mode})")
    print(json.dumps(payload, ensure_ascii=False, indent=2))


def score_current_paper():
    paper_ctx = get_current_paper_context()
    if not paper_ctx:
        sys.exit("error: no active paper")

    paper_md = ensure_paper_md(paper_ctx["slug"])
    text = paper_md.read_text(encoding="utf-8")
    graph_path, _ = ensure_research_artifacts(paper_ctx["slug"])
    graph = json.loads(graph_path.read_text(encoding="utf-8"))

    critiques_dir = paper_dir(paper_ctx["slug"]) / "critiques"
    validations_dir = paper_dir(paper_ctx["slug"]) / "validations"
    scores_dir = paper_dir(paper_ctx["slug"]) / "scores"

    critique_files = sorted(critiques_dir.glob("*.json")) if critiques_dir.exists() else []
    validation_files = sorted(validations_dir.glob("*.json")) if validations_dir.exists() else []
    score_files = sorted(scores_dir.glob("*.json")) if scores_dir.exists() else []

    latest_critique = critique_files[-1] if critique_files else None
    latest_validation = validation_files[-1] if validation_files else None
    previous_score_file = score_files[-1] if score_files else None

    critique_data = json.loads(latest_critique.read_text(encoding="utf-8")) if latest_critique else {}
    validation_data = json.loads(latest_validation.read_text(encoding="utf-8")) if latest_validation else {}
    previous_score = json.loads(previous_score_file.read_text(encoding="utf-8")).get("total", 0) if previous_score_file else 0

    node_count = len(graph.get("nodes", []))
    edge_count = len(graph.get("edges", []))
    heading_count = len(re.findall(r"^##\s+", text, re.MULTILINE))
    paragraph_count = len([p for p in text.split("\n\n") if p.strip()])
    clarity_hint = critique_data.get("result", {}).get("scores", {}).get("clarity", 0)
    argument_hint = critique_data.get("result", {}).get("scores", {}).get("argument_strength", 0)
    counterargument_hint = critique_data.get("result", {}).get("scores", {}).get("counterargument", 0)
    validity_score = validation_data.get("result", {}).get("validity_score", 0)
    validation_items = validation_data.get("validated_items", 0)
    latest_research = latest_research_run(paper_ctx["slug"])
    latest_research_payload = latest_research[1] if latest_research else {}
    total_findings = sum(len(item.get("findings", [])) for item in latest_research_payload.get("evidence", [])) if latest_research_payload else 0

    if total_findings >= 6 and validation_items >= 3:
        evidence_grounding = 3
    elif total_findings >= 2:
        evidence_grounding = 2
    elif total_findings >= 1:
        evidence_grounding = 1
    else:
        evidence_grounding = 0

    if validation_items >= 5 and validity_score >= 0.9:
        citation_validity = 3
    elif validation_items >= 1 and validity_score >= 0.75:
        citation_validity = 2
    elif validation_items >= 1:
        citation_validity = 1
    else:
        citation_validity = 0

    if heading_count >= 6 and paragraph_count >= 8:
        argument_chain = 3
    elif heading_count >= 4 and paragraph_count >= 5:
        argument_chain = 2
    elif heading_count >= 1:
        argument_chain = 1
    else:
        argument_chain = 0

    thesis_alignment = critique_data.get("result", {}).get("scores", {}).get("thesis_alignment", 0)

    if counterargument_hint >= 3:
        counterargument = 3
    elif counterargument_hint >= 2:
        counterargument = 2
    elif latest_critique is not None:
        counterargument = 1
    else:
        counterargument = 0

    if clarity_hint >= 3:
        clarity = 3
    elif clarity_hint >= 2:
        clarity = 2
    elif paragraph_count >= 3:
        clarity = 1
    else:
        clarity = 0

    if thesis_alignment <= 0 and not (paper_ctx.get("frontmatter", {}).get("thesis", "").startswith("[待填写")):
        argument_chain = max(argument_chain - 1, 0)
        counterargument = max(counterargument - 1, 0)

    if edge_count >= 15:
        graph_coherence = 3
    elif edge_count >= 5:
        graph_coherence = 2
    elif edge_count >= 1:
        graph_coherence = 1
    else:
        graph_coherence = 0

    thesis_text = paper_ctx.get("frontmatter", {}).get("thesis", "")
    thesis_placeholder = thesis_text.startswith("[待填写")
    total = evidence_grounding + citation_validity + argument_chain + counterargument + clarity + graph_coherence
    if thesis_placeholder:
        total = max(total - 1, 0)

    payload = {
        "paper": paper_ctx["slug"],
        "scores": {
            "evidence_grounding": evidence_grounding,
            "citation_validity": citation_validity,
            "argument_chain": argument_chain,
            "counterargument": counterargument,
            "clarity": clarity,
            "graph_coherence": graph_coherence,
        },
        "old_total": previous_score,
        "total": total,
        "band": (
            "excellent" if total >= 16 else
            "good" if total >= 13 else
            "developing" if total >= 7 else
            "draft"
        ),
        "inputs": {
            "graph_nodes": node_count,
            "graph_edges": edge_count,
            "heading_count": heading_count,
            "paragraph_count": paragraph_count,
            "validation_items": validation_items,
            "validity_score": validity_score,
            "critique_present": latest_critique is not None,
            "validation_present": latest_validation is not None,
            "thesis_alignment": thesis_alignment,
        },
        "rationale": {
            "evidence_grounding": f"node_count={node_count}",
            "citation_validity": f"validation_items={validation_items}, validity_score={validity_score}",
            "argument_chain": f"heading_count={heading_count}, paragraph_count={paragraph_count}, thesis_alignment={thesis_alignment}",
            "counterargument": f"counterargument_hint={counterargument_hint}, thesis_alignment={thesis_alignment}",
            "clarity": f"clarity_hint={clarity_hint}, paragraph_count={paragraph_count}",
            "graph_coherence": f"edge_count={edge_count}",
        },
        "generated_at": datetime.now().isoformat(timespec="seconds"),
    }
    out = save_artifact(paper_ctx["slug"], "scores", payload)
    payload["saved_to"] = str(out.relative_to(ROOT))
    append_generic_result(
        paper_ctx["slug"],
        "score",
        "recorded",
        "agent_run",
        f"rubric score total={total}/18",
        old_score=previous_score,
        new_score=total,
    )
    print(json.dumps(payload, ensure_ascii=False, indent=2))


def run_write(section_title=None):
    paper_ctx = get_current_paper_context()
    if not paper_ctx:
        sys.exit("error: no active paper")

    latest = latest_research_run(paper_ctx["slug"])
    if not latest:
        sys.exit("error: no research run found for current paper")
    _, research_payload = latest

    writer = start_agent("writer")
    if isinstance(writer, dict):
        writer = WriterAgent(writer.get("agent_id"))

    all_findings = []
    for item in research_payload.get("evidence", []):
        all_findings.extend(item.get("findings", []))
    thesis = paper_ctx.get("frontmatter", {}).get("thesis")
    paper_text = ensure_paper_md(paper_ctx["slug"]).read_text(encoding="utf-8")
    existing_titles = re.findall(r"^##\s+(.+)$", paper_text, re.MULTILINE)
    resolved_title = route_section_title(research_payload.get("topic", "Research Draft"), existing_titles, requested_title=section_title)
    draft = writer.draft_section(resolved_title, all_findings, thesis=thesis)

    payload = {
        "paper": paper_ctx["slug"],
        "source_research_topic": research_payload.get("topic"),
        "section_title": resolved_title,
        "draft": draft,
        "generated_at": datetime.now().isoformat(timespec="seconds"),
    }
    out = save_artifact(paper_ctx["slug"], "drafts", payload)
    payload["saved_to"] = str(out.relative_to(ROOT))
    append_generic_result(paper_ctx["slug"], "write", "recorded", "agent_run", f"draft generated: {payload['section_title']}")
    print(json.dumps(payload, ensure_ascii=False, indent=2))


def run_critique():
    paper_ctx = get_current_paper_context()
    if not paper_ctx:
        sys.exit("error: no active paper")

    drafts_dir = paper_dir(paper_ctx["slug"]) / "drafts"
    files = sorted(drafts_dir.glob("*.json")) if drafts_dir.exists() else []
    if not files:
        sys.exit("error: no draft found for current paper")
    draft_payload = json.loads(files[-1].read_text(encoding="utf-8"))

    critic = start_agent("critic")
    if isinstance(critic, dict):
        critic = CriticAgent(critic.get("agent_id"))

    criteria = ["clarity", "argument_strength", "counterargument", "evidence_grounding"]
    thesis = paper_ctx.get("frontmatter", {}).get("thesis")
    result = critic.evaluate_content(draft_payload.get("draft", ""), criteria, thesis=thesis)
    payload = {
        "paper": paper_ctx["slug"],
        "draft_source": str(files[-1].relative_to(ROOT)),
        "criteria": criteria,
        "result": result,
        "generated_at": datetime.now().isoformat(timespec="seconds"),
    }
    out = save_artifact(paper_ctx["slug"], "critiques", payload)
    payload["saved_to"] = str(out.relative_to(ROOT))
    append_generic_result(paper_ctx["slug"], "critique", "recorded", "agent_run", "critique generated from latest draft")
    print(json.dumps(payload, ensure_ascii=False, indent=2))


def run_validate():
    paper_ctx = get_current_paper_context()
    if not paper_ctx:
        sys.exit("error: no active paper")

    latest = latest_research_run(paper_ctx["slug"])
    if not latest:
        sys.exit("error: no research run found for current paper")
    _, research_payload = latest

    validator = start_agent("validator")
    if isinstance(validator, dict):
        validator = ValidatorAgent(validator.get("agent_id"))

    all_findings = []
    for item in research_payload.get("evidence", []):
        all_findings.extend(item.get("findings", []))
    result = validator.validate_evidence(all_findings)
    payload = {
        "paper": paper_ctx["slug"],
        "research_topic": research_payload.get("topic"),
        "validated_items": len(all_findings),
        "result": result,
        "generated_at": datetime.now().isoformat(timespec="seconds"),
    }
    out = save_artifact(paper_ctx["slug"], "validations", payload)
    payload["saved_to"] = str(out.relative_to(ROOT))
    append_generic_result(paper_ctx["slug"], "validate", "recorded", "agent_run", f"validated {len(all_findings)} findings")
    print(json.dumps(payload, ensure_ascii=False, indent=2))


def decide_keep_discard(slug):
    scores_dir = paper_dir(slug) / "scores"
    files = sorted(scores_dir.glob("*.json")) if scores_dir.exists() else []
    if not files:
        sys.exit("error: no score artifacts found for current paper")
    latest = json.loads(files[-1].read_text(encoding="utf-8"))
    old_total = int(latest.get("old_total", 0) or 0)
    new_total = int(latest.get("total", 0) or 0)
    band = latest.get("band")
    scores = latest.get("scores", {})

    if new_total > old_total:
        decision = "keep"
        reason = f"score improved from {old_total} to {new_total}"
    else:
        decision = "discard"
        reason = f"score did not improve ({old_total} -> {new_total})"

    reason_parts = [reason]
    if band:
        reason_parts.append(f"band={band}")
    low_dimensions = [k for k, v in scores.items() if v <= 1]
    if low_dimensions:
        reason_parts.append("weak dimensions: " + ", ".join(low_dimensions))

    payload = {
        "paper": slug,
        "old_total": old_total,
        "new_total": new_total,
        "decision": decision,
        "reason": "; ".join(reason_parts),
        "band": band,
        "scores": scores,
        "generated_at": datetime.now().isoformat(timespec="seconds"),
    }
    out = save_artifact(slug, "decisions", payload)
    payload["saved_to"] = str(out.relative_to(ROOT))
    append_generic_result(
        slug,
        "decision",
        decision,
        "agent_run",
        reason,
        old_score=old_total,
        new_score=new_total,
    )
    return payload


def run_iterate(topic, section_title=None):
    paper_ctx = get_current_paper_context()
    if not paper_ctx:
        sys.exit("error: no active paper")

    snapshot_path = begin_iteration_snapshot(paper_ctx["slug"])

    run_research(topic)
    run_write(section_title=section_title)
    apply_latest_draft(section_title=section_title)
    run_critique()
    run_validate()
    score_current_paper()

    decision = decide_keep_discard(paper_ctx["slug"])
    rollback = None
    if decision["decision"] == "discard":
        rollback = restore_iteration_snapshot(paper_ctx["slug"], snapshot_path)
        append_generic_result(
            paper_ctx["slug"],
            "discard_rollback",
            "recorded",
            "agent_run",
            "restored snapshot after discard",
            old_score=decision["old_total"],
            new_score=decision["new_total"],
        )

    summary = {
        "paper": paper_ctx["slug"],
        "topic": topic,
        "snapshot": str(Path(snapshot_path).relative_to(ROOT)),
        "decision": decision,
        "rollback": rollback,
    }
    out = save_artifact(paper_ctx["slug"], "iterations", summary)
    summary["saved_to"] = str(out.relative_to(ROOT))
    print(json.dumps(summary, ensure_ascii=False, indent=2))


def run_research(topic):
    ensure_default_orchestrator()
    researcher = start_agent("researcher")
    if isinstance(researcher, dict):
        researcher = ResearcherAgent(researcher.get("agent_id"))

    paper_ctx = get_current_paper_context()
    raw_dir = RAW
    run_id = datetime.now().strftime("%Y%m%d_%H%M%S")

    thesis = (paper_ctx or {}).get("frontmatter", {}).get("thesis")
    existing_sections = re.findall(r"^##\s+(.+)$", ensure_paper_md(paper_ctx['slug']).read_text(encoding='utf-8'), re.MULTILINE) if paper_ctx else []
    questions = researcher.generate_research_questions(topic, thesis=thesis, existing_sections=existing_sections)
    extra_terms = []
    if thesis and not thesis.startswith("[待填写"):
        extra_terms.extend(re.findall(r"[\w\u4e00-\u9fff]{2,}", thesis))
    extra_terms.extend(re.findall(r"[\w\u4e00-\u9fff]{2,}", topic))
    extra_terms.extend(existing_sections[:4])
    evidence_by_question = []
    for question in questions:
        findings = researcher.retrieve_evidence(question, raw_dir=raw_dir, extra_terms=extra_terms)
        evidence_by_question.append({
            "question": question,
            "findings": findings,
        })

    payload = {
        "run_id": run_id,
        "topic": topic,
        "paper": {
            "slug": paper_ctx["slug"] if paper_ctx else None,
            "thesis": (paper_ctx or {}).get("frontmatter", {}).get("thesis"),
        },
        "raw_dir_exists": raw_dir.exists(),
        "questions": questions,
        "evidence": evidence_by_question,
        "generated_at": datetime.now().isoformat(timespec="seconds"),
    }

    if paper_ctx:
        out = save_research_run(paper_ctx["slug"], payload)
        payload["saved_to"] = str(out.relative_to(ROOT))
        graph_info = merge_research_into_graph(paper_ctx["slug"], payload)
        results_path = append_research_to_results(paper_ctx["slug"], payload)
        payload["graph_updated"] = {
            "path": str(graph_info["graph_path"].relative_to(ROOT)),
            "nodes_added": graph_info["nodes_added"],
            "edges_added": graph_info["edges_added"],
        }
        payload["results_updated"] = str(results_path.relative_to(ROOT))

    print(json.dumps(payload, ensure_ascii=False, indent=2))

def run_git(*args, check=False):
    try:
        r = subprocess.run(["git", *args], cwd=ROOT, capture_output=True, text=True)
        if check and r.returncode != 0:
            sys.exit(f"git {' '.join(args)} failed: {r.stderr}")
        return r.stdout
    except FileNotFoundError:
        return ""


def read_current():
    if not CURRENT.exists():
        return None
    val = CURRENT.read_text(encoding="utf-8").strip()
    return normalize_slug(val) if val else None


def paper_dir(slug):
    return PAPERS / normalize_slug(slug)


def parse_frontmatter(path):
    """Minimal YAML frontmatter parser supporting scalars, inline lists, and simple multiline lists."""
    if not path.exists():
        return {}
    text = path.read_text(encoding="utf-8")
    m = re.match(r"^---\n(.*?)\n---", text, re.DOTALL)
    if not m:
        return {}
    fm = {}
    lines = m.group(1).splitlines()
    i = 0
    while i < len(lines):
        line = lines[i]
        if ":" not in line or line.lstrip().startswith("#"):
            i += 1
            continue
        key, _, val = line.partition(":")
        key = key.strip()
        val = val.strip()
        if val.startswith("[") and val.endswith("]"):
            inner = val[1:-1].strip()
            fm[key] = ([x.strip().strip('"').strip("'") for x in inner.split(",") if x.strip()] if inner else [])
        elif not val:
            items = []
            j = i + 1
            while j < len(lines):
                nxt = lines[j].strip()
                if nxt.startswith("- "):
                    items.append(nxt[2:].strip().strip('"').strip("'"))
                    j += 1
                    continue
                if not nxt:
                    j += 1
                    continue
                break
            fm[key] = items
            i = j - 1
        else:
            fm[key] = val.strip('"').strip("'")
        i += 1
    return fm


def cmd_new(args):
    slug = args.slug
    if not re.match(r"^[a-z0-9][a-z0-9-]*$", slug):
        sys.exit("error: slug must be lowercase letters, digits, and dashes")
    d = paper_dir(slug)
    if d.exists():
        sys.exit(f"error: papers/{slug}/ already exists")
    title = args.title or input("Title: ").strip() or slug
    branch = args.branch or run_git("rev-parse", "--abbrev-ref", "HEAD").strip() or "main"
    d.mkdir(parents=True)
    (d / "paper.md").write_text(
        PAPER_TEMPLATE.format(
            slug=slug, title=title, branch=branch,
            date=datetime.now().strftime("%Y-%m-%d"),
        ),
        encoding="utf-8",
    )
    (d / "paper_graph.json").write_text(
        json.dumps(
            {
                "_meta": {"last_scan_commit": None, "scanned_at": None, "slug": slug},
                "nodes": [],
                "edges": [],
                "metadata": {"iteration": 0, "total_nodes": 0, "total_edges": 0},
            },
            indent=2,
            ensure_ascii=False,
        ),
        encoding="utf-8",
    )
    (d / "reader_prompts.md").write_text(
        READER_PROMPTS_TEMPLATE.format(title=title), encoding="utf-8"
    )
    (d / "results.tsv").write_text(RESULTS_HEADER, encoding="utf-8")
    (d / "graphify-out").mkdir(exist_ok=True)
    print(f"created papers/{slug}/")
    print(f"next: fill thesis/scope in papers/{slug}/paper.md, then run:")
    print(f"  scripts/autowrite switch {slug}")


def cmd_switch(args):
    slug = args.slug
    if not paper_dir(slug).exists():
        sys.exit(f"error: papers/{slug}/ not found. run: autowrite new {slug}")
    current = read_current()
    if current and current != slug:
        dirty = run_git("status", "--porcelain", str(paper_dir(current))).strip()
        if dirty:
            print(f"warning: uncommitted changes in papers/{current}/:")
            print(dirty)
            if input("continue? [y/N] ").strip().lower() != "y":
                sys.exit(1)
    PAPERS.mkdir(exist_ok=True)
    CURRENT.write_text(slug + "\n", encoding="utf-8")
    print(f"switched to: {slug}")
    cmd_status(argparse.Namespace())


def cmd_status(args):
    slug = read_current()
    if not slug:
        print("no active paper. run: autowrite new <slug>")
        return
    d = paper_dir(slug)
    if not d.exists():
        sys.exit(f"error: papers/.current points to missing papers/{slug}/")
    fm = parse_frontmatter(d / "paper.md")
    print(f"active: {slug}")
    print(f"  title:    {fm.get('title', '?')}")
    print(f"  thesis:   {fm.get('thesis', '?')}")
    print(f"  scope_in: {fm.get('scope_in', [])}")
    print(f"  branch:   {fm.get('branch_baseline', '?')}")
    tsv = d / "results.tsv"
    if tsv.exists():
        lines = tsv.read_text(encoding="utf-8").strip().splitlines()
        if len(lines) > 1:
            print("recent iterations:")
            for line in lines[-5:]:
                print(f"  {line}")


def cmd_list(args):
    if not PAPERS.exists():
        print("no papers/")
        return
    current = read_current()
    rows = []
    for d in sorted(PAPERS.iterdir()):
        if not d.is_dir():
            continue
        fm = parse_frontmatter(d / "paper.md")
        rows.append((d.name == current, d.name, fm.get("title", "?")))
    if not rows:
        print("no papers/ subdirectories")
        return
    width = max(len(r[1]) for r in rows)
    for active, name, title in rows:
        mark = "*" if active else " "
        print(f"{mark} {name.ljust(width)}  {title}")


def cmd_validate(args):
    slug = read_current()
    if not slug:
        sys.exit("error: no active paper (papers/.current missing)")
    d = paper_dir(slug)
    if not d.exists():
        sys.exit(f"error: papers/{slug}/ missing")

    errors, warnings = [], []
    paper_md = d / "paper.md"
    if not paper_md.exists():
        errors.append("paper.md missing")
    else:
        fm = parse_frontmatter(paper_md)
        for k in ("slug", "title", "thesis"):
            if not fm.get(k):
                errors.append(f"frontmatter missing: {k}")
        if fm.get("slug") and fm["slug"] != slug:
            errors.append(f"frontmatter slug ({fm['slug']}) != directory ({slug})")
        if fm.get("thesis", "").startswith("[待填写"):
            warnings.append("thesis still placeholder")
        text = paper_md.read_text(encoding="utf-8")
        h1 = re.search(r"^#\s+(.+)$", text, re.MULTILINE)
        if h1 and fm.get("title") and h1.group(1).strip() != fm["title"]:
            warnings.append(f"H1 ({h1.group(1).strip()}) != title ({fm['title']})")
        branch = run_git("rev-parse", "--abbrev-ref", "HEAD").strip()
        if fm.get("branch_baseline") and branch and fm["branch_baseline"] != branch:
            warnings.append(f"git branch ({branch}) != branch_baseline ({fm['branch_baseline']})")
        for subset_file in fm.get("raw_subset", []) or []:
            if not (RAW / subset_file).exists():
                errors.append(f"raw_subset file missing: {subset_file}")

    pg = d / "paper_graph.json"
    if not pg.exists():
        errors.append("paper_graph.json missing")
    else:
        try:
            data = json.loads(pg.read_text(encoding="utf-8"))
            if "_meta" not in data:
                warnings.append("paper_graph.json missing _meta block")
        except json.JSONDecodeError as e:
            errors.append(f"paper_graph.json parse error: {e}")

    rp = d / "reader_prompts.md"
    if not rp.exists():
        warnings.append("reader_prompts.md missing")
    else:
        count = len(re.findall(r"^##\s+P\d", rp.read_text(encoding="utf-8"), re.MULTILINE))
        if count < 3:
            warnings.append(f"reader_prompts.md has {count} prompts (need ≥ 3)")

    tsv = d / "results.tsv"
    if not tsv.exists():
        errors.append("results.tsv missing")
    elif not tsv.read_text(encoding="utf-8").startswith("iteration\t"):
        errors.append("results.tsv header mismatch")

    for e in errors:
        print(f"  [FAIL] {e}")
    for w in warnings:
        print(f"  [WARN] {w}")
    if not errors and not warnings:
        print(f"  [OK] papers/{slug}/ passed all checks")
    sys.exit(1 if errors else 0)


def cmd_kb_sync(args):
    slug = read_current()
    if not slug:
        sys.exit("error: no active paper")
    d = paper_dir(slug)
    pg = d / "paper_graph.json"

    last_commit = None
    if pg.exists():
        try:
            last_commit = json.loads(pg.read_text(encoding="utf-8")).get("_meta", {}).get("last_scan_commit")
        except Exception:
            pass

    dirty = run_git("status", "--porcelain", str(RAW)).strip()
    if dirty and not args.force:
        print("warning: raw/ has uncommitted changes:")
        print(dirty)
        print("commit first for reliable incremental sync, or rerun with --force for full rescan.")
        sys.exit(1)

    cmd = [sys.executable, str(BUILD_SCRIPT), "--paper", slug, "--scan", str(RAW), "--save-json"]
    if last_commit and not args.full:
        changed = run_git("diff", "--name-only", last_commit, "HEAD", "--", "raw/").strip().splitlines()
        changed = [c for c in changed if c]
        if not changed:
            print(f"no raw/ changes since {last_commit[:8]}. nothing to sync.")
            return
        print(f"{len(changed)} file(s) changed since {last_commit[:8]}:")
        for c in changed:
            print(f"  {c}")
        cmd.append("--merge")
    else:
        print("full rescan of raw/")

    print("running:", " ".join(cmd))
    r = subprocess.run(cmd)
    if r.returncode != 0:
        sys.exit(r.returncode)

    head = run_git("rev-parse", "HEAD").strip()
    if head and pg.exists():
        try:
            data = json.loads(pg.read_text(encoding="utf-8"))
            data.setdefault("_meta", {})
            data["_meta"]["last_scan_commit"] = head
            data["_meta"]["scanned_at"] = datetime.now().isoformat(timespec="seconds")
            pg.write_text(json.dumps(data, indent=2, ensure_ascii=False), encoding="utf-8")
        except Exception as e:
            print(f"warning: could not update _meta: {e}")

    tsv = d / "results.tsv"
    if tsv.exists():
        with tsv.open("a", encoding="utf-8") as f:
            f.write(f"-\t{head[:8] if head else '-'}\t-\t-\t-\tkb_sync\t-\traw/ synced\n")
    print("kb-sync complete. run: scripts/autowrite validate")


def main():
    p = argparse.ArgumentParser(prog="autowrite", description="multi-paper management")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("new", help="scaffold a new paper")
    sp.add_argument("slug")
    sp.add_argument("--title")
    sp.add_argument("--branch")
    sp.set_defaults(func=cmd_new)

    sp = sub.add_parser("switch", help="set active paper")
    sp.add_argument("slug")
    sp.set_defaults(func=cmd_switch)

    sp = sub.add_parser("status", help="show current paper")
    sp.set_defaults(func=cmd_status)

    sp = sub.add_parser("list", help="list all papers")
    sp.set_defaults(func=cmd_list)

    sp = sub.add_parser("validate", help="integrity check on current paper")
    sp.set_defaults(func=cmd_validate)

    sp = sub.add_parser("kb-sync", help="incremental graph update from raw/")
    sp.add_argument("--full", action="store_true", help="force full rescan")
    sp.add_argument("--force", action="store_true", help="ignore uncommitted raw/ changes")
    sp.set_defaults(func=cmd_kb_sync)

    sp = sub.add_parser("agent", help="manage local agents")
    agent_sub = sp.add_subparsers(dest="agent_cmd", required=True)

    asp = agent_sub.add_parser("start", help="start an agent")
    asp.add_argument("agent_type", choices=["orchestrator", "researcher", "writer", "critic", "validator"])
    asp.add_argument("--id", dest="agent_id")
    asp.set_defaults(func=lambda args: start_agent(args.agent_type, args.agent_id))

    asp = agent_sub.add_parser("stop", help="stop an agent by id")
    asp.add_argument("agent_id")
    asp.set_defaults(func=lambda args: stop_agent(args.agent_id))

    asp = agent_sub.add_parser("list", help="list running agents")
    asp.set_defaults(func=lambda args: list_agents_cmd())

    asp = agent_sub.add_parser("run", help="run an agent workflow")
    run_sub = asp.add_subparsers(dest="run_cmd", required=True)

    rsp = run_sub.add_parser("research", help="run basic research workflow")
    rsp.add_argument("--topic", required=True)
    rsp.set_defaults(func=lambda args: run_research(args.topic))

    wsp = run_sub.add_parser("write", help="generate draft from latest research run")
    wsp.add_argument("--section-title")
    wsp.set_defaults(func=lambda args: run_write(section_title=args.section_title))

    asp2 = run_sub.add_parser("apply-draft", help="apply latest draft into paper.md")
    asp2.add_argument("--section-title")
    asp2.set_defaults(func=lambda args: apply_latest_draft(section_title=args.section_title))

    csp = run_sub.add_parser("critique", help="critique latest draft")
    csp.set_defaults(func=lambda args: run_critique())

    vsp = run_sub.add_parser("validate", help="validate latest research evidence")
    vsp.set_defaults(func=lambda args: run_validate())

    ssp = run_sub.add_parser("score", help="score current paper with basic rubric")
    ssp.set_defaults(func=lambda args: score_current_paper())

    dsp = run_sub.add_parser("decide", help="decide keep or discard from latest scores")
    dsp.set_defaults(func=lambda args: print(json.dumps(decide_keep_discard(get_current_paper_context()['slug']), ensure_ascii=False, indent=2)))

    isp = run_sub.add_parser("iterate", help="run research -> write -> apply-draft -> critique -> validate -> score -> decide")
    isp.add_argument("--topic", required=True)
    isp.add_argument("--section-title")
    isp.set_defaults(func=lambda args: run_iterate(args.topic, section_title=args.section_title))

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
